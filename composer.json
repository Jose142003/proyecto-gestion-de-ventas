{
    "name": "pic/sistema-carrito-compras",
    "description": "PIC - Sistema de Carrito de Compras y Gestión de Inventario",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "ext-pdo": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "~12.5.0"
    },
    "autoload": {
        "classmap": [
            "conexion/",
            "config/"
        ]
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "test-coverage": "phpunit --colors=always --coverage-html coverage/"
    }
}
