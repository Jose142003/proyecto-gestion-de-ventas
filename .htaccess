<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^manifest\.json$ manifest.php [L,QSA]
    RewriteRule ^interfaz_usuario/pagina_modernizada\.html$ interfaz_usuario/pagina_modernizada_check.php [L,QSA]
    ErrorDocument 404 /proyecto/interfaz_usuario/404.php
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "\.(sql|md|log)$">
    Require all denied
</FilesMatch>

<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

# Protect .env files
RedirectMatch 404 /\.env

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(vendor|backups/backups|logs|sql|tests) - [F,L]
    RewriteRule ^backups_db/ - [F,L]
</IfModule>
